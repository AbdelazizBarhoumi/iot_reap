APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

# Laravel Reverb (WebSocket Server)
# Generate unique values for production: php artisan reverb:install
REVERB_APP_ID=your-app-id
REVERB_APP_KEY=your-reverb-key
REVERB_APP_SECRET=your-reverb-secret
REVERB_HOST="localhost"
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
# Proxmox Configuration
# PROXMOX_HOST: IP or hostname of your Proxmox server (e.g., 192.168.1.100 or pve.local)
PROXMOX_HOST=your-proxmox-host
PROXMOX_PORT=8006
PROXMOX_REALM=pam
# PROXMOX_TOKEN_ID: Format is user@realm!tokenname (e.g., apiuser@pam!mytoken)
PROXMOX_TOKEN_ID=user@pam!tokenname
# PROXMOX_TOKEN_SECRET: UUID format secret from Proxmox API token creation
PROXMOX_TOKEN_SECRET=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
PROXMOX_VERIFY_SSL=true
PROXMOX_TIMEOUT=30
PROXMOX_NODE_LOAD_THRESHOLD=0.85
PROXMOX_RETRY_ATTEMPTS=3
PROXMOX_RETRY_DELAY_INITIAL=10
PROXMOX_CLONE_TIMEOUT=120
PROXMOX_CLONE_POLL_INTERVAL=5
PROXMOX_CACHE_TTL=30

# Guacamole Remote Desktop Configuration
# GUACAMOLE_URL: Full URL to Guacamole server (e.g., http://localhost:8080/guacamole)
GUACAMOLE_URL=http://your-guacamole-host:8080/guacamole
GUACAMOLE_USERNAME=guacadmin
# GUACAMOLE_PASSWORD: Change from default 'guacadmin' in production!
GUACAMOLE_PASSWORD=changeme
GUACAMOLE_DATA_SOURCE=MySQL
GUACAMOLE_IDLE_TIMEOUT=30
GUACAMOLE_TOKEN_EXPIRATION=300

# Guacamole Connection Credentials (for provisioned VMs)
# These are default credentials used when connecting to VMs via Guacamole
RDP_USERNAME=Administrator
RDP_PASSWORD=changeme
VNC_PASSWORD=changeme
SSH_USERNAME=root
SSH_PASSWORD=changeme
# SSH_PRIVATE_KEY: Absolute path to SSH private key file (optional, for key-based auth)
SSH_PRIVATE_KEY=/path/to/your/private/key
SSH_PASSPHRASE=changeme
