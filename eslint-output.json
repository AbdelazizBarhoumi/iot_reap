                   </p>\r\n                                </CardContent>\r\n                            </Card>\r\n                        ) : (\r\n                            <div>\r\n                                {activeReservations.map((r) => (\r\n                                    <ReservationCard\r\n                                        key={r.id}\r\n                                        reservation={r}\r\n                                        onCancel={handleCancel}\r\n                                        actionLoading={actionLoading}\r\n                                    />\r\n                                ))}\r\n                            </div>\r\n                        )}\r\n                    </TabsContent>\r\n                    {/* Upcoming (pending + approved) */}\r\n                    <TabsContent value=\"upcoming\" className=\"mt-4\">\r\n                        {loading ? (\r\n                            <div className=\"space-y-4\">\r\n                                {[1, 2, 3].map((i) => (\r\n                                    <Skeleton key={i} className=\"h-40 w-full\" />\r\n                                ))}\r\n                            </div>\r\n                        ) : upcomingReservations.length === 0 ? (\r\n                            <Card>\r\n                                <CardContent className=\"flex flex-col items-center justify-center py-12\">\r\n                                    <Calendar className=\"mb-4 h-12 w-12 text-muted-foreground\" />\r\n                                    <p className=\"mb-4 text-center text-muted-foreground\">\r\n                                        No upcoming reservations.\r\n                                    </p>\r\n                                    <Button onClick={handleOpenDialog}>\r\n                                        <Plus className=\"mr-2 h-4 w-4\" />\r\n                                        Request Your First Reservation\r\n                                    </Button>\r\n                                </CardContent>\r\n                            </Card>\r\n                        ) : (\r\n                            <div>\r\n                                {/* Pending first, then approved */}\r\n                                {pendingReservations.length > 0 && (\r\n                                    <div className=\"mb-6\">\r\n                                        <h3 className=\"mb-3 flex items-center gap-2 text-sm font-medium text-muted-foreground\">\r\n                                            <Clock className=\"h-4 w-4\" />\r\n                                            Pending Approval (\r\n                                            {pendingReservations.length})\r\n                                        </h3>\r\n                                        {pendingReservations.map((r) => (\r\n                                            <ReservationCard\r\n                                                key={r.id}\r\n                                                reservation={r}\r\n                                                onCancel={handleCancel}\r\n                                                actionLoading={actionLoading}\r\n                                            />\r\n                                        ))}\r\n                                    </div>\r\n                                )}\r\n                                {approvedReservations.length > 0 && (\r\n                                    <div>\r\n                                        <h3 className=\"mb-3 flex items-center gap-2 text-sm font-medium text-muted-foreground\">\r\n                                            <CheckCircle2 className=\"h-4 w-4\" />\r\n                                            Approved (\r\n                                            {approvedReservations.length})\r\n                                        </h3>\r\n                                        {approvedReservations.map((r) => (\r\n                                            <ReservationCard\r\n                                                key={r.id}\r\n                                                reservation={r}\r\n                                                onCancel={handleCancel}\r\n                                                actionLoading={actionLoading}\r\n                                            />\r\n                                        ))}\r\n                                    </div>\r\n                                )}\r\n                            </div>\r\n                        )}\r\n                    </TabsContent>\r\n                    {/* History (completed, rejected, cancelled) */}\r\n                    <TabsContent value=\"history\" className=\"mt-4\">\r\n                        {loading ? (\r\n                            <div className=\"space-y-4\">\r\n                                {[1, 2, 3].map((i) => (\r\n                                    <Skeleton key={i} className=\"h-32 w-full\" />\r\n                                ))}\r\n                            </div>\r\n                        ) : pastReservations.length === 0 ? (\r\n                            <Card>\r\n                                <CardContent className=\"flex flex-col items-center justify-center py-12\">\r\n                                    <Calendar className=\"mb-4 h-12 w-12 text-muted-foreground\" />\r\n                                    <p className=\"text-center text-muted-foreground\">\r\n                                        No reservation history yet.\r\n                                    </p>\r\n                                </CardContent>\r\n                            </Card>\r\n                        ) : (\r\n                            <div>\r\n                                {pastReservations.map((r) => (\r\n                                    <ReservationCard\r\n                                        key={r.id}\r\n                                        reservation={r}\r\n                                        onCancel={handleCancel}\r\n                                        actionLoading={actionLoading}\r\n                                    />\r\n                                ))}\r\n                            </div>\r\n                        )}\r\n                    </TabsContent>\r\n                </Tabs>\r\n            </div>\r\n            {/* Request Reservation Dialog */}\r\n            <RequestReservationDialog\r\n                open={dialogOpen}\r\n                onOpenChange={setDialogOpen}\r\n                devices={devices}\r\n                devicesLoading={devicesLoading}\r\n                onSubmit={handleSubmitReservation}\r\n                submitting={submitting}\r\n            />\r\n        </AppLayout>\r\n    );\r\n}\r\n\r\n","usedDeprecatedRules":[]},{"filePath":"D:\\projects\\iot_reap\\resources\\js\\pages\\sessions\\index.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\projects\\iot_reap\\resources\\js\\pages\\sessions\\show.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\projects\\iot_reap\\resources\\js\\pages\\settings\\appearance.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\projects\\iot_reap\\resources\\js\\pages\\settings\\password.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\projects\\iot_reap\\resources\\js\\pages\\settings\\profile.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErr