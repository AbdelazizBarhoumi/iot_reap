es, results]","fix":{"range":[2518,2561],"text":"[attempt, handleSubmit, quiz.time_limit_minutes, results]"}}]}],"suppressedMessages":[],"errorCount":4,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"/**\r\n * QuizTaker Component\r\n * Student-facing quiz taking interface.\r\n */\r\nimport { motion, AnimatePresence } from 'framer-motion';\r\nimport {\r\n    AlertCircle,\r\n    ArrowLeft,\r\n    ArrowRight,\r\n    CheckCircle2,\r\n    Clock,\r\n    Send,\r\n    XCircle,\r\n} from 'lucide-react';\r\nimport { useState, useEffect, useCallback } from 'react';\r\nimport { toast } from 'sonner';\r\nimport { Badge } from '@/components/ui/badge';\r\nimport { Button } from '@/components/ui/button';\r\nimport { Card, CardContent, CardHeader, CardTitle } from '@/components/ui/card';\r\nimport { Label } from '@/components/ui/label';\r\nimport { Progress } from '@/components/ui/progress';\r\nimport { RadioGroup, RadioGroupItem } from '@/components/ui/radio-group';\r\nimport { Textarea } from '@/components/ui/textarea';\r\nimport type {\r\n    Quiz,\r\n    QuizQuestion,\r\n    QuizAttempt,\r\n    QuizAnswerInput,\r\n    QuizSubmitResponse,\r\n    QuizResult,\r\n} from '@/types/quiz.types';\r\ninterface QuizTakerProps {\r\n    quiz: Quiz;\r\n    onComplete?: (attempt: QuizAttempt) => void;\r\n    onCancel?: () => void;\r\n}\r\nexport function QuizTaker({ quiz, onComplete, onCancel }: QuizTakerProps) {\r\n    const [attempt, setAttempt] = useState<QuizAttempt | null>(null);\r\n    const [currentIndex, setCurrentIndex] = useState(0);\r\n    const [answers, setAnswers] = useState<Map<number, QuizAnswerInput>>(\r\n        new Map(),\r\n    );\r\n    const [isStarting, setIsStarting] = useState(false);\r\n    const [isSubmitting, setIsSubmitting] = useState(false);\r\n    const [results, setResults] = useState<QuizSubmitResponse | null>(null);\r\n    const [timeRemaining, setTimeRemaining] = useState<number | null>(null);\r\n    const questions = quiz.questions || [];\r\n    const currentQuestion = questions[currentIndex];\r\n    const progress = ((currentIndex + 1) / questions.length) * 100;\r\n    // Timer effect\r\n    useEffect(() => {\r\n        if (!attempt || !quiz.time_limit_minutes || results) return;\r\n        const startTime = new Date(attempt.started_at!).getTime();\r\n        const endTime = startTime + quiz.time_limit_minutes * 60 * 1000;\r\n        const updateTimer = () => {\r\n            const remaining = Math.max(\r\n                0,\r\n                Math.floor((endTime - Date.now()) / 1000),\r\n            );\r\n            setTimeRemaining(remaining);\r\n            if (remaining === 0) {\r\n                handleSubmit();\r\n            }\r\n        };\r\n        updateTimer();\r\n        const interval = setInterval(updateTimer, 1000);\r\n        return () => clearInterval(interval);\r\n    }, [attempt, quiz.time_limit_minutes, results]);\r\n    const formatTime = (seconds: number): string => {\r\n        const mins = Math.floor(seconds / 60);\r\n        const secs = seconds % 60;\r\n        return `${mins}:${secs.toString().padStart(2, '0')}`;\r\n    };\r\n    const startQuiz = async () => {\r\n        setIsStarting(true);\r\n        try {\r\n            const response = await fetch(`/quizzes/${quiz.id}/start`, {\r\n                method: 'POST',\r\n                headers: {\r\n                    'X-Requested-With': 'XMLHttpRequest',\r\n                    'X-XSRF-TOKEN':\r\n                        document.cookie\r\n                            .split('; ')\r\n                            .find((row) => row.startsWith('XSRF-TOKEN='))\r\n                            ?.split('=')[1] ?? '',\r\n                },\r\n                credentials: 'include',\r\n            });\r\n            if (!response.ok) {\r\n                const data = await response.json();\r\n                throw new Error(data.error || 'Failed to start quiz');\r\n            }\r\n            const data = await response.json();\r\n            setAttempt(data.attempt);\r\n        } catch (error: unknown) {\r\n            toast.error(error.message || 'Failed to start quiz');\r\n        } finally {\r\n            setIsStarting(false);\r\n        }\r\n    };\r\n    const setAnswer = (\r\n        questionId: number,\r\n        answer: Partial<QuizAnswerInput>,\r\n    ) => {\r\n        setAnswers((prev) => {\r\n            const newAnswers = new Map(prev);\r\n            newAnswers.set(questionId, {\r\n                question_id: questionId,\r\n                ...prev.get(questionId),\r\n                ...answer,\r\n            });\r\n            return newAnswers;\r\n        });\r\n    };\r\n    const handleSubmit = async () => {\r\n        if (!attempt) return;\r\n        setIsSubmitting(true);\r\n        try {\r\n            const answersArray = Array.from(answers.values());\r\n            const response = await fetch(\r\n                `/quiz-attempts/${attempt.id}/submit`,\r\n                {\r\n                    method: 'POST',\r\n                    headers: {\r\n                        'Content-Type': 'application/json',\r\n                        'X-Requested-With': 'XMLHttpRequest',\r\n                        'X-XSRF-TOKEN':\r\n                            document.cookie\r\n                                .split('; ')\r\n                                .find((row) => row.startsWith('XSRF-TOKEN='))\r\n                                ?.split('=')[1] ?? '',\r\n                    },\r\n                    credentials: 'include',\r\n                    body: JSON.stringify({ answers: answersArray }),\r\n                },\r\n            );\r\n            if (!response.ok) {\r\n                const data = await response.json();\r\n                throw new Error(data.error || 'Failed to submit quiz');\r\n            }\r\n            const data: QuizSubmitResponse = await response.json();\r\n            setResults(data);\r\n            onComplete?.(data.attempt);\r\n        } catch (error: unknown) {\r\n            toast.error(error.message || 'Failed to submit quiz');\r\n        } finally {\r\n            setIsSubmitting(false);\r\n        }\r\n    };\r\n    // Show start screen\r\n    if (!attempt) {\r\n        return (\r\n            <Card className=\"mx-auto max-w-2xl shadow-card\">\r\n                <CardHeader className=\"text-center\">\r\n                    <CardTitle className=\"font-heading text-2xl\">\r\n                        {quiz.title}\r\n                    </CardTitle>\r\n                    {quiz.description && (\r\n                        <p className=\"mt-2 text-muted-foreground\">\r\n                            {quiz.description}\r\n                        </p>\r\n                    )}\r\n                </CardHeader>\r\n                <CardContent className=\"space-y-6\">\r\n                    <div className=\"grid grid-cols-2 gap-4 text-center\">\r\n                        <div className=\"rounded-lg bg-muted/50 p-4\">\r\n                            <p className=\"text-2xl font-bold text-primary\">\r\n                                {quiz.question_count}\r\n                            </p>\r\n                            <p className=\"text-sm text-muted-foreground\">\r\n                                Questions\r\n                            </p>\r\n                        </div>\r\n                        <div className=\"rounded-lg bg-muted/50 p-4\">\r\n                            <p className=\"text-2xl font-bold text-primary\">\r\n                                {quiz.passing_score}%\r\n                            </p>\r\n                            <p className=\"text-sm text-muted-foreground\">\r\n                                Passing Score\r\n                            </p>\r\n                        </div>\r\n                        {quiz.time_limit_minutes && (\r\n                            <div className=\"rounded-lg bg-muted/50 p-4\">\r\n                                <p className=\"text-2xl font-bold text-primary\">\r\n                                    {quiz.time_limit_minutes}\r\n                                </p>\r\n                                <p className=\"text-sm text-muted-foreground\">\r\n                                    Minutes\r\n                                </p>\r\n                            </div>\r\n                        )}\r\n                        {quiz.max_attempts && (\r\n                            <div className=\"rounded-lg bg-muted/50 p-4\">\r\n                                <p className=\"text-2xl font-bold text-primary\">\r\n                                    {quiz.max_attempts -\r\n                                        (quiz.attempt_count || 0)}\r\n                                </p>\r\n                                <p className=\"text-sm text-muted-foreground\">\r\n                                    Attempts Left\r\n                                </p>\r\n                            </div>\r\n                        )}\r\n                    </div>\r\n                    {quiz.has_passed && (\r\n                        <div className=\"flex items-center gap-2 rounded-lg bg-green-100 p-4 dark:bg-green-900/30\">\r\n                            <CheckCircle2 className=\"h-5 w-5 text-green-600\" />\r\n                            <span className=\"text-green-800 dark:text-green-400\">\r\n                                You've already passed this quiz!\r\n                            </span>\r\n                        </div>\r\n                    )}\r\n                    <div className=\"flex justify-center gap-3 pt-4\">\r\n                        {onCancel && (\r\n                            <Button variant=\"outline\" onClick={onCancel}>\r\n                                Cancel\r\n                            </Button>\r\n                        )}\r\n                        <Button\r\n                            size=\"lg\"\r\n                            onClick={startQuiz}\r\n                            disabled={isStarting || !quiz.can_attempt}\r\n                        >\r\n                            {isStarting ? 'Starting...' : 'Start Quiz'}\r\n                        </Button>\r\n                    </div>\r\n                </CardContent>\r\n            </Card>\r\n        );\r\n    }\r\n    // Show results\r\n    if (results) {\r\n        return (\r\n            <Card className=\"mx-auto max-w-2xl shadow-card\">\r\n                <CardHeader className=\"text-center\">\r\n                    <div\r\n                        className={`mx-auto flex h-20 w-20 items-center justify-center rounded-full ${\r\n                            results.attempt.passed\r\n                                ? 'bg-green-100 dark:bg-green-900/30'\r\n                                : 'bg-red-100 dark:bg-red-900/30'\r\n                        }`}\r\n                    >\r\n                        {results.attempt.passed ? (\r\n                            <CheckCircle2 className=\"h-10 w-10 text-green-600\" />\r\n                        ) : (\r\n                            <XCircle className=\"h-10 w-10 text-red-600\" />\r\n                        )}\r\n                    </div>\r\n                    <CardTitle className=\"mt-4 font-heading text-2xl\">\r\n                        {results.attempt.passed\r\n                            ? 'Congratulations!'\r\n                            : 'Keep Trying!'}\r\n                    </CardTitle>\r\n                    <p className=\"text-muted-foreground\">\r\n                        {results.attempt.passed\r\n                            ? 'You passed the quiz!'\r\n                            : `You need ${quiz.passing_score}% to pass.`}\r\n                    </p>\r\n                </CardHeader>\r\n                <CardContent className=\"space-y-6\">\r\n                    <div className=\"text-center\">\r\n                        <p className=\"text-5xl font-bold text-primary\">\r\n                            {results.attempt.percentage.toFixed(0)}%\r\n                        </p>\r\n                        <p className=\"text-muted-foreground\">\r\n                            {results.attempt.score} /{' '}\r\n                            {results.attempt.total_points} points\r\n                        </p>\r\n                    </div>\r\n                    {quiz.show_correct_answers && results.results && (\r\n                        <div className=\"space-y-3\">\r\n                            <h3 className=\"font-semibold\">Review Answers</h3>\r\n                            {results.results.map((result, index) => {\r\n                                const question = questions.find(\r\n                                    (q) => q.id === result.question_id,\r\n                                );\r\n                                return (\r\n                                    <div\r\n                                        key={result.question_id}\r\n                                        className={`rounded-lg p-3 ${\r\n                                            result.is_correct\r\n                                                ? 'border border-green-200 bg-green-50 dark:border-green-800 dark:bg-green-900/20'\r\n                                                : 'border border-red-200 bg-red-50 dark:border-red-800 dark:bg-red-900/20'\r\n                                        }`}\r\n                                    >\r\n                                        <div className=\"flex items-start gap-2\">\r\n                                            {result.is_correct ? (\r\n                                                <CheckCircle2 className=\"mt-0.5 h-4 w-4 text-green-600\" />\r\n                                            ) : (\r\n                                                <XCircle className=\"mt-0.5 h-4 w-4 text-red-600\" />\r\n                                            )}\r\n                                            <div className=\"flex-1\">\r\n                                                <p className=\"text-sm font-medium\">\r\n                                                    {index + 1}.{' '}\r\n                                                    {question?.question}\r\n                                                </p>\r\n                                                {result.explanation && (\r\n                                                    <p className=\"mt-1 text-xs text-muted-foreground\">\r\n                                                        {result.explanation}\r\n                                                    </p>\r\n                                                )}\r\n                                            </div>\r\n                                            <Badge\r\n                                                variant=\"outline\"\r\n                                                className=\"text-xs\"\r\n                                            >\r\n                                                {result.points_earned} pts\r\n                                            </Badge>\r\n                                        </div>\r\n                                    </div>\r\n                                );\r\n                            })}\r\n                        </div>\r\n                    )}\r\n                    <div className=\"flex justify-center pt-4\">\r\n                        <Button onClick={onCancel}>Continue</Button>\r\n                    </div>\r\n                </CardContent>\r\n            </Card>\r\n        );\r\n    }\r\n    // Show quiz question\r\n    return (\r\n        <div className=\"mx-auto max-w-2xl space-y-4\">\r\n            {/* Progress bar and timer */}\r\n            <div className=\"flex items-center justify-between gap-4\">\r\n                <div className=\"flex-1\">\r\n                    <Progress value={progress} className=\"h-2\" />\r\n                    <p className=\"mt-1 text-xs text-muted-foreground\">\r\n                        Question {currentIndex + 1} of {questions.length}\r\n                    </p>\r\n                </div>\r\n                {timeRemaining !== null && (\r\n                    <Badge\r\n                        variant={timeRemaining < 60 ? 'destructive' : 'outline'}\r\n                        className=\"text-sm\"\r\n                    >\r\n                        <Clock className=\"mr-1 h-3 w-3\" />\r\n                        {formatTime(timeRemaining)}\r\n                    </Badge>\r\n                )}\r\n            </div>\r\n            {/* Question card */}\r\n            <AnimatePresence mode=\"wait\">\r\n                <motion.div\r\n                    key={currentQuestion.id}\r\n                    initial={{ opacity: 0, x: 20 }}\r\n                    animate={{ opacity: 1, x: 0 }}\r\n                    exit={{ opacity: 0, x: -20 }}\r\n                >\r\n                    <Card className=\"shadow-card\">\r\n                        <CardHeader>\r\n                            <div className=\"flex items-center justify-between\">\r\n                                <Badge variant=\"outline\">\r\n                                    {currentQuestion.type_label}\r\n                                </Badge>\r\n                                <span className=\"text-sm text-muted-foreground\">\r\n                                    {currentQuestion.points}{' '}\r\n                                    {currentQuestion.points === 1\r\n                                        ? 'point'\r\n                                        : 'points'}\r\n                                </span>\r\n                            </div>\r\n                            <CardTitle className=\"mt-2 font-heading text-lg\">\r\n                                {currentQuestion.question}\r\n                            </CardTitle>\r\n                        </CardHeader>\r\n                        <CardContent>\r\n                            {/* Multiple choice / True-False */}\r\n                            {(currentQuestion.type === 'multiple_choice' ||\r\n                                currentQuestion.type === 'true_false') && (\r\n                                <RadioGroup\r\n                                    value={\r\n                                        answers\r\n                                            .get(currentQuestion.id)\r\n                                            ?.selected_option_id?.toString() ||\r\n                                        ''\r\n                                    }\r\n                                    onValueChange={(value: string) =>\r\n                                        setAnswer(currentQuestion.id, {\r\n                                            selected_option_id: Number(value),\r\n                                        })\r\n                                    }\r\n                                    className=\"space-y-3\"\r\n                                >\r\n                                    {currentQuestion.options.map((option) => (\r\n                                        <div\r\n                                            key={option.id}\r\n                                            className=\"flex cursor-pointer items-center space-x-3 rounded-lg border border-border p-3 transition-colors hover:bg-muted/50\"\r\n                                            onClick={() =>\r\n                                                setAnswer(currentQuestion.id, {\r\n                                                    selected_option_id:\r\n                                                        option.id,\r\n                                                })\r\n                                            }\r\n                                        >\r\n                                            <RadioGroupItem\r\n                                                value={option.id.toString()}\r\n                                                id={`opt-${option.id}`}\r\n                                            />\r\n                                            <Label\r\n                                                htmlFor={`opt-${option.id}`}\r\n                                                className=\"flex-1 cursor-pointer font-normal\"\r\n                                            >\r\n                                                {option.option_text}\r\n                                            </Label>\r\n                                        </div>\r\n                                    ))}\r\n                                </RadioGroup>\r\n                            )}\r\n                            {/* Short answer */}\r\n                            {currentQuestion.type === 'short_answer' && (\r\n                                <Textarea\r\n                                    value={\r\n                                        answers.get(currentQuestion.id)\r\n                                            ?.text_answer || ''\r\n                                    }\r\n                                    onChange={(e) =>\r\n                                        setAnswer(currentQuestion.id, {\r\n                                            text_answer: e.target.value,\r\n                                        })\r\n                                    }\r\n                                    placeholder=\"Type your answer here...\"\r\n                                    rows={4}\r\n                                />\r\n                            )}\r\n                        </CardContent>\r\n                    </Card>\r\n                </motion.div>\r\n            </AnimatePresence>\r\n            {/* Navigation */}\r\n            <div className=\"flex items-center justify-between\">\r\n                <Button\r\n                    variant=\"outline\"\r\n                    onClick={() =>\r\n                        setCurrentIndex(Math.max(0, currentIndex - 1))\r\n                    }\r\n                    disabled={currentIndex === 0}\r\n                >\r\n                    <ArrowLeft className=\"mr-2 h-4 w-4\" />\r\n                    Previous\r\n                </Button>\r\n                {currentIndex < questions.length - 1 ? (\r\n                    <Button onClick={() => setCurrentIndex(currentIndex + 1)}>\r\n                        Next\r\n                        <ArrowRight className=\"ml-2 h-4 w-4\" />\r\n                    </Button>\r\n                ) : (\r\n                    <Button\r\n                        onClick={handleSubmit}\r\n                        disabled={isSubmitting}\r\n                        className=\"bg-green-600 hover:bg-green-700\"\r\n                    >\r\n                        <Send className=\"mr-2 h-4 w-4\" />\r\n                        {isSubmitting ? 'Submitting...' : 'Submit Quiz'}\r\n                    </Button>\r\n                )}\r\n            </div>\r\n            {/* Question dots */}\r\n            <div className=\"flex flex-wrap justify-center gap-2\">\r\n                {questions.map((q, index) => {\r\n                    const hasAnswer = answers.has(q.id);\r\n                    return (\r\n                        <button\r\n                            key={q.id}\r\n                            onClick={() => setCurrentIndex(index)}\r\n                            className={`h-8 w-8 rounded-full text-xs font-medium transition-colors ${\r\n                                index === currentIndex\r\n                                    ? 'bg-primary text-primary-foreground'\r\n                                    : hasAnswer\r\n                                      ? 'bg-green-100 text-green-800 dark:bg-green-900/50 dark:text-green-400'\r\n                                      : 'bg-muted text-muted-foreground hover:bg-muted/80'\r\n                            }`}\r\n                        >\r\n                            {index + 1}\r\n                        </button>\r\n                    );\r\n                })}\r\n            </div>\r\n        </div>\r\n    );\r\n}\r\n\r\n\r\n","usedDeprecatedRules":[]},{"filePath":"D:\\projects\\iot_reap\\resources\\js\\components\\quiz\\__tests__\\QuizBuilder.test.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":2,"message":"'lessonId' is defined but never used. Allowed unused args must match /^_/u.","line":35,"column":24,"nodeType":"Identifier","messageId":"unusedVar","endLine":35,"endColumn":32},{"ruleId":"@typescript-eslint/no-unused-vars","severity":2,"message":"'user' is assigned a value but never used. Allowed unused vars must match /^_/u.","line":198,"column":19,"nodeType":"Identifier","messageId":"unusedVar","endLine":198,"endColumn":23}],"suppressedMessages":[],"errorCount":2,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { render, screen, waitFor } from '@testing-library/react';\r\nimport userEvent from '@testing-library/user-event';\r\nimport { useState } from 'react';\r\nimport { describe, expect, it, vi, beforeEach } from 'vitest';\r\n// Mock child components\r\nvi.mock('../QuestionEditor', () => ({\r\n    QuestionEditor: ({ isOpen, onClose, onSave }: unknown) =>\r\n        isOpen ? (\r\n            <div data-testid=\"question-editor\">\r\n                <button onClick={onClose}>Close Editor</button>\r\n                <button \r\n                    onClick={() => onSave({\r\n                        type: 'multiple_choice',\r\n                        question: 'Test Question',\r\n                        points: 10,\r\n                        options: [\r\n                            { option_text: 'Option A', is_correct: true },\r\n                            { option_text: 'Option B', is_correct: false },\r\n                        ],\r\n                    })}\r\n                >\r\n                    Save Question\r\n                </button>\r\n            </div>\r\n        ) : null,\r\n}));\r\n// Mock toast notifications\r\nvi.mock('sonner', () => ({\r\n    toast: {\r\n        success: vi.fn(),\r\n        error: vi.fn(),\r\n    },\r\n}));\r\n// Simplified QuizBuilder component for testing\r\nconst QuizBuilder = ({ lessonId, quiz, onQuizCreated }: unknown) => {\r\n    const [isCreating, setIsCreating] = useState(false);\r\n    const [showAddQuestion, setShowAddQuestion] = useState(false);\r\n    const handleCreateQuiz = async () => {\r\n        setIsCreating(true);\r\n        // Simulate API call\r\n        await new Promise(resolve => setTimeout(resolve, 100));\r\n        onQuizCreated?.({ id: 1, title: 'New Quiz' });\r\n        setIsCreating(false);\r\n    };\r\n    const handlePublish = async () => {\r\n        // Simulate API call\r\n        await new Promise(resolve => setTimeout(resolve, 100));\r\n    };\r\n    if (!quiz) {\r\n        return (\r\n            <div>\r\n                <h2>Create Quiz</h2>\r\n                <label htmlFor=\"title\">Title</label>\r\n                <input id=\"title\" name=\"title\" />\r\n                <label htmlFor=\"description\">Description</label>\r\n                <textarea id=\"description\" name=\"description\" />\r\n                <button \r\n                    onClick={handleCreateQuiz}\r\n                    disabled={isCreating}\r\n                >\r\n                    {isCreating ? 'Creating...' : 'Create Quiz'}\r\n                </button>\r\n            </div>\r\n        );\r\n    }\r\n    return (\r\n        <div>\r\n            <h1>{quiz.title}</h1>\r\n            <h2>Quiz Settings</h2>\r\n            <div>\r\n                <label htmlFor=\"quiz-title\">Title</label>\r\n                <input id=\"quiz-title\" defaultValue={quiz.title} />\r\n            </div>\r\n            <div>\r\n                <label htmlFor=\"shuffle_questions\">Shuffle Questions</label>\r\n                <button \r\n                    role=\"switch\" \r\n                    aria-checked={quiz.shuffle_questions}\r\n                    data-testid=\"switch-shuffle_questions\"\r\n                >\r\n                    {quiz.shuffle_questions ? 'ON' : 'OFF'}\r\n                </button>\r\n            </div>\r\n            <h3>Questions ({quiz.questions?.length || 0})</h3>\r\n            {quiz.questions?.map((question: unknown) => (\r\n                <div key={question.id} data-testid={`reorder-item-${question.id}`}>\r\n                    <span>{question.question}</span>\r\n                    <button onClick={() => window.confirm('Are you sure?') && console.log('deleted')}>Delete Question</button>\r\n                </div>\r\n            ))}\r\n            <button onClick={() => setShowAddQuestion(true)}>Add Question</button>\r\n            <button onClick={handlePublish}>\r\n                {quiz.is_published ? 'Unpublish Quiz' : 'Publish Quiz'}\r\n            </button>\r\n            <button\r\n                onClick={() => window.confirm('Are you sure?') && {}}\r\n                className=\"destructive\"\r\n            >\r\n                Delete Quiz\r\n            </button>\r\n            {showAddQuestion && (\r\n                <div data-testid=\"question-editor\">\r\n                    <button onClick={() => setShowAddQuestion(false)}>Close Editor</button>\r\n                    <button onClick={() => setShowAddQuestion(false)}>Save Question</button>\r\n                </div>\r\n            )}\r\n        </div>\r\n    );\r\n};\r\ndescribe('QuizBuilder Component', () => {\r\n    const mockOnQuizCreated = vi.fn();\r\n    const sampleQuiz = {\r\n        id: 1,\r\n        title: 'Sample Quiz',\r\n        description: 'A sample quiz for testing',\r\n        shuffle_questions: false,\r\n        is_published: false,\r\n        questions: [\r\n            {\r\n                id: 1,\r\n                question: 'What is 2+2?',\r\n                type: 'multiple_choice',\r\n            },\r\n            {\r\n                id: 2,\r\n                question: 'The sky is blue',\r\n                type: 'true_false',\r\n            },\r\n        ],\r\n    };\r\n    beforeEach(() => {\r\n        vi.clearAllMocks();\r\n    });\r\n    describe('Creation Mode (No Quiz)', () => {\r\n        const creationProps = {\r\n            lessonId: 'lesson-123',\r\n            quiz: null,\r\n            onQuizCreated: mockOnQuizCreated,\r\n        };\r\n        it('renders quiz creation form when no quiz provided', () => {\r\n            render(<QuizBuilder {...creationProps} />);\r\n            expect(screen.getByRole('heading', { level: 2, name: /create quiz/i })).toBeInTheDocument();\r\n            expect(screen.getByLabelText(/title/i)).toBeInTheDocument();\r\n            expect(screen.getByLabelText(/description/i)).toBeInTheDocument();\r\n            expect(screen.getByRole('button', { name: /create quiz/i })).toBeInTheDocument();\r\n        });\r\n        it('allows user to fill out quiz creation form', async () => {\r\n            const user = userEvent.setup();\r\n            render(<QuizBuilder {...creationProps} />);\r\n            const titleInput = screen.getByLabelText(/title/i);\r\n            const descriptionInput = screen.getByLabelText(/description/i);\r\n            await user.type(titleInput, 'New Quiz Title');\r\n            await user.type(descriptionInput, 'New quiz description');\r\n            expect(titleInput).toHaveValue('New Quiz Title');\r\n            expect(descriptionInput).toHaveValue('New quiz description');\r\n        });\r\n        it('creates quiz when form is submitted', async () => {\r\n            const user = userEvent.setup();\r\n            render(<QuizBuilder {...creationProps} />);\r\n            const createButton = screen.getByRole('button', { name: /create quiz/i });\r\n            await user.click(createButton);\r\n            await waitFor(() => {\r\n                expect(mockOnQuizCreated).toHaveBeenCalled();\r\n            });\r\n        });\r\n        it('disables create button while creating quiz', async () => {\r\n            const user = userEvent.setup();\r\n            render(<QuizBuilder {...creationProps} />);\r\n            const createButton = screen.getByRole('button', { name: /create quiz/i });\r\n            await user.click(createButton);\r\n            expect(screen.getByRole('button', { name: /creating\\.\\.\\./i })).toBeDisabled();\r\n        });\r\n    });\r\n    describe('Editor Mode (Quiz Exists)', () => {\r\n        const editorProps = {\r\n            lessonId: 'lesson-123',\r\n            quiz: sampleQuiz,\r\n            onQuizCreated: mockOnQuizCreated,\r\n        };\r\n        it('renders quiz editor when quiz is provided', () => {\r\n            render(<QuizBuilder {...editorProps} />);\r\n            expect(screen.getByText('Sample Quiz')).toBeInTheDocument();\r\n            expect(screen.getByText(/quiz settings/i)).toBeInTheDocument();\r\n            expect(screen.getByText(/questions \\(2\\)/i)).toBeInTheDocument();\r\n            expect(screen.getByRole('button', { name: /publish quiz/i })).toBeInTheDocument();\r\n        });\r\n        it('displays quiz questions', () => {\r\n            render(<QuizBuilder {...editorProps} />);\r\n            expect(screen.getByText('What is 2+2?')).toBeInTheDocument();\r\n            expect(screen.getByText('The sky is blue')).toBeInTheDocument();\r\n        });\r\n        it('shows unpublish button when quiz is published', () => {\r\n            const publishedQuiz = { ...sampleQuiz, is_published: true };\r\n            render(<QuizBuilder {...editorProps} quiz={publishedQuiz} />);\r\n            expect(screen.getByRole('button', { name: /unpublish quiz/i })).toBeInTheDocument();\r\n        });\r\n        it('toggles quiz settings switches', async () => {\r\n            const user = userEvent.setup();\r\n            render(<QuizBuilder {...editorProps} />);\r\n            const shuffleQuestionsSwitch = screen.getByTestId('switch-shuffle_questions');\r\n            expect(shuffleQuestionsSwitch).toHaveTextContent('OFF');\r\n        });\r\n        it('deletes quiz with confirmation', async () => {\r\n            const user = userEvent.setup();\r\n            vi.stubGlobal('confirm', vi.fn(() => true));\r\n            render(<QuizBuilder {...editorProps} />);\r\n            const deleteButton = screen.getByRole('button', { name: /delete quiz/i });\r\n            await user.click(deleteButton);\r\n            expect(window.confirm).toHaveBeenCalledWith(\r\n                expect.stringContaining('Are you sure')\r\n            );\r\n        });\r\n        it('does not delete quiz when confirmation is cancelled', async () => {\r\n            const user = userEvent.setup();\r\n            vi.stubGlobal('confirm', vi.fn(() => false));\r\n            render(<QuizBuilder {...editorProps} />);\r\n            const deleteButton = screen.getByRole('button', { name: /delete quiz/i });\r\n            await user.click(deleteButton);\r\n            expect(window.confirm).toHaveBeenCalled();\r\n        });\r\n    });\r\n    describe('Question Management', () => {\r\n        const editorProps = {\r\n            lessonId: 'lesson-123',\r\n            quiz: sampleQuiz,\r\n            onQuizCreated: mockOnQuizCreated,\r\n        };\r\n        it('opens question editor when add question button is clicked', async () => {\r\n            const user = userEvent.setup();\r\n            render(<QuizBuilder {...editorProps} />);\r\n            const addButton = screen.getByRole('button', { name: /add question/i });\r\n            await user.click(addButton);\r\n            expect(screen.getByTestId('question-editor')).toBeInTheDocument();\r\n        });\r\n        it('closes question editor when close button is clicked', async () => {\r\n            const user = userEvent.setup();\r\n            render(<QuizBuilder {...editorProps} />);\r\n            const addButton = screen.getByRole('button', { name: /add question/i });\r\n            await user.click(addButton);\r\n            const closeButton = screen.getByRole('button', { name: /close editor/i });\r\n            await user.click(closeButton);\r\n            expect(screen.queryByTestId('question-editor')).not.toBeInTheDocument();\r\n        });\r\n        it('deletes question when delete button is clicked', async () => {\r\n            const user = userEvent.setup();\r\n            vi.stubGlobal('confirm', vi.fn(() => true));\r\n            render(<QuizBuilder {...editorProps} />);\r\n            const deleteButtons = screen.getAllByRole('button', { name: /delete question/i });\r\n            await user.click(deleteButtons[0]);\r\n            // In a real implementation, we would check the question was removed\r\n            expect(window.confirm).toHaveBeenCalled();\r\n        });\r\n    });\r\n});\r\n\r\n\r\n","usedDeprecatedRules":[]},{"filePath":"D:\\projects\\iot_reap\\resources\\js\\components\\quiz\\__tests__\\QuizTaker.test.tsx","messages":[{"ruleId":"react-hooks/rules-of-hooks","severity":2,"message":"React Hook \"useEffect\" is called in function \"handleSubmit\" that is neither a React function component nor a custom React Hook function. React component names must start with an uppercase letter. React Hook names must start with the word \"use\".","line":62,"column":5,"nodeType":"Identifier","endLine":62,"endColumn":14},{"ruleId":"react-hooks/exhaustive-deps","severity":1,"message":"React Hook useEffect has unnecessary dependencies: 'attempt', 'quiz.time_limit_minutes', and 'timeRemaining'. Either exclude them or remove the dependency array. Outer scope values like 'attempt' aren't valid dependencies because mutating them doesn't re-render the component.","line":78,"column":8,"nodeType":"ArrayExpression","endLine":78,"endColumn":57,"suggestions":[{"desc":"Update the dependencies array to be: []","fix":{"range":[3305,3354],"text":"[]"}}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":2,"message":"'handleStart' is assigned a value but never used. Allowed unused vars must match /^_/u.","line":79,"column":11,"nodeType":"Identifier","messageId":"unusedVar","endLine":79,"endColumn":22}],"suppressedMessages":[],"errorCount":2,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { render, screen, waitFor } from '@testing-library/react';\r\nimport userEvent from '@testing-library/user-event';\r\nimport { useState, useEffect } from 'react';\r\nimport { describe, expect, it, vi, beforeEach, afterEach } from 'vitest';\r\n// Mock toast notifications\r\nvi.mock('sonner', () => ({\r\n    toast: {\r\n        success: vi.fn(),\r\n        error: vi.fn(),\r\n    },\r\n}));\r\n// Mock framer-motion\r\nvi.mock('framer-motion', () => ({\r\n    AnimatePresence: ({ children }: unknown) => <div data-testid=\"animate-presence\">{children}</div>,\r\n    motion: {\r\n        div: ({ children, ...props }: unknown) => <div data-testid=\"motion-div\" {...props}>{children}</div>,\r\n    },\r\n}));\r\n// Simplified QuizTaker component for testing\r\nconst QuizTaker = ({ quiz, onComplete, onCancel }: unknown) => {\r\n    interface Attempt {\r\n        id: number;\r\n        quiz_id: unknown;\r\n        started_at: string;\r\n        passed?: boolean;\r\n        percentage?: number;\r\n        score?: number;\r\n    }\r\n    const [attempt, setAttempt] = useState<Attempt | null>(null);\r\n    const [currentIndex, setCurrentIndex] = useState(0);\r\n    const [answers, setAnswers] = useState(new Map());\r\n    const [results, setResults] = useState<unknown[] | null>(null);\r\n    const [isStarting, setIsStarting] = useState(false);\r\n    const [isSubmitting, setIsSubmitting] = useState(false);\r\n    const [timeRemaining, setTimeRemaining] = useState<number | null>(null);\r\n    // handleSubmit defined before useEffect\r\n    const handleStart = async () => {\r\n        setIsStarting(true);\r\n        await new Promise(resolve => setTimeout(resolve, 100));\r\n        const mockAttempt: Attempt = {\r\n            id: 1,\r\n            quiz_id: quiz.id,\r\n            started_at: new Date().toISOString(),\r\n        };\r\n        setAttempt(mockAttempt);\r\n        setIsStarting(false);\r\n    };\r\n    const handleSubmit = async () => {\r\n        setIsSubmitting(true);\r\n        await new Promise(resolve => setTimeout(resolve, 100));\r\n        const mockResults: unknown[] = [\r\n            { question_id: 1, is_correct: true, points_earned: 10, explanation: 'Correct!' },\r\n            { question_id: 2, is_correct: false, points_earned: 0, explanation: 'Try again' },\r\n        ];\r\n        const completedAttempt: Attempt = attempt ? {\r\n            ...attempt,\r\n            passed: true,\r\n            percentage: 85,\r\n            score: 25,\r\n        } : { id: 1, quiz_id: quiz.id, started_at: new Date().toISOString(), passed: true, percentage: 85, score: 25 };\r\n    // Timer effect\r\n    useEffect(() => {\r\n        if (attempt && quiz.time_limit_minutes && timeRemaining === null) {     \r\n            const startTime = new Date(attempt.started_at).getTime();\r\n            const endTime = startTime + (quiz.time_limit_minutes * 60 * 1000);  \r\n            const remaining = Math.max(0, endTime - Date.now());\r\n            setTimeRemaining(Math.floor(remaining / 1000));\r\n        }\r\n        if ((timeRemaining ?? 0) > 0) {\r\n            const timer = setTimeout(() => {\r\n                setTimeRemaining(prev => (prev ?? 0) > 0 ? (prev ?? 0) - 1 : 0);\r\n            }, 1000);\r\n            return () => clearTimeout(timer);\r\n        } else if (timeRemaining === 0 && attempt) {\r\n            // Auto-submit when time runs out\r\n            handleSubmit();\r\n        }\r\n    }, [attempt, timeRemaining, quiz.time_limit_minutes]);\r\n    const handleStart = async () => {\r\n        setIsStarting(true);\r\n        await new Promise(resolve => setTimeout(resolve, 100));\r\n        const mockAttempt = {\r\n            id: 1,\r\n            quiz_id: quiz.id,\r\n            started_at: new Date().toISOString(),\r\n        };\r\n        setAttempt(mockAttempt);\r\n        setIsStarting(false);\r\n    };\r\n        setResults(mockResults);\r\n        setIsSubmitting(false);\r\n        onComplete?.(completedAttempt);\r\n    };\r\n    const formatTime = (seconds: number) => {\r\n        const mins = Math.floor(seconds / 60);\r\n        const secs = seconds % 60;\r\n        return `${mins}:${secs.toString().padStart(2, '0')}`;\r\n    };\r\n    // Results screen\r\n    if (results) {\r\n        return (\r\n            <div>\r\n                <h1>Quiz Passed!</h1>\r\n                <div>85%</div>\r\n                <div>25 / 30 points</div>\r\n                {quiz.show_correct_answers && (\r\n                    <div>\r\n                        <h2>Review Your Answers</h2>\r\n                        {quiz.questions.map((question: unknown) => (\r\n                            <div key={question.id}>\r\n                                <div>{question.question}</div>\r\n                                <div>{question.explanation}</div>\r\n                            </div>\r\n                        ))}\r\n                    </div>\r\n                )}\r\n                <button>Continue</button>\r\n            </div>\r\n        );\r\n    }\r\n    // Quiz taking screen\r\n    if (attempt) {\r\n        const currentQuestion = quiz.questions[currentIndex];\r\n        return (\r\n            <div>\r\n                <div role=\"progressbar\" aria-valuenow={currentIndex + 1} aria-valuemax={quiz.questions.length}>\r\n                    Progress: {Math.round(((currentIndex + 1) / quiz.questions.length) * 100)}%\r\n                </div>\r\n                <div>Question {currentIndex + 1} of {quiz.questions.length}</div>\r\n                {timeRemaining !== null && (\r\n                    <div data-variant={timeRemaining < 60 ? 'destructive' : 'default'}>\r\n                        {formatTime(timeRemaining)}\r\n                    </div>\r\n                )}\r\n                <div>\r\n                    <h2>{currentQuestion.question}</h2>\r\n                    <span>{currentQuestion.type_label}</span>\r\n                    <span>{currentQuestion.points} points</span>\r\n                    {/* Question inputs based on type */}\r\n                    {currentQuestion.type === 'multiple_choice' || currentQuestion.type === 'true_false' ? (\r\n                        <div role=\"radiogroup\">\r\n                            {currentQuestion.options.map((option: unknown) => (\r\n                                <label key={option.id}>\r\n                                    <input\r\n                                        type=\"radio\"\r\n                                        name={`question-${currentQuestion.id}`}\r\n                                        value={option.id}\r\n                                        onChange={() => setAnswers(prev => new Map(prev).set(currentQuestion.id, { selected_option_id: option.id }))}\r\n                                    />\r\n                                    {option.option_text}\r\n                                </label>\r\n                            ))}\r\n                        </div>\r\n                    ) : currentQuestion.type === 'short_answer' ? (\r\n                        <textarea\r\n                            placeholder=\"Enter your answer\"\r\n                            onChange={(e) => setAnswers(prev => new Map(prev).set(currentQuestion.id, { text_answer: e.target.value }))}\r\n                        />\r\n                    ) : null}\r\n                </div>\r\n                {/* Navigation */}\r\n                <div>\r\n                    {currentIndex > 0 && (\r\n                        <button onClick={() => setCurrentIndex(prev => prev - 1)}>Previous</button>\r\n                    )}\r\n                    {currentIndex < quiz.questions.length - 1 ? (\r\n                        <button onClick={() => setCurrentIndex(prev => prev + 1)}>Next</button>\r\n                    ) : (\r\n                        <button \r\n                            onClick={handleSubmit}\r\n                            disabled={isSubmitting}\r\n                        >\r\n                            {isSubmitting ? 'Submitting...' : 'Submit Quiz'}\r\n                        </button>\r\n                    )}\r\n                </div>\r\n                {/* Question indicators */}\r\n                <div>\r\n                    {quiz.questions.map((_: unknown, index: number) => (\r\n                        <button\r\n                            key={index}\r\n                            onClick={() => setCurrentIndex(index)}\r\n                            aria-label={`Go to question ${index + 1}`}\r\n                            className={answers.has(quiz.questions[index].id) ? 'bg-green-500' : 'bg-gray-300'}\r\n                        />\r\n                    ))}\r\n                </div>\r\n            </div>\r\n        );\r\n    }\r\n    // Start screen\r\n    return (\r\n        <div>\r\n            <h1>{quiz.title}</h1>\r\n            {quiz.description && <p>{quiz.description}</p>}\r\n            <div>\r\n                <div>{quiz.question_count} questions</div>\r\n                <div>{quiz.passing_score}% to pass</div>\r\n                <div>\r\n                    {quiz.time_limit_minutes ? `${quiz.time_limit_minutes} minutes` : 'No time limit'}\r\n                </div>\r\n                <div>\r\n                    {quiz.max_attempts ? `${quiz.max_attempts} attempts allowed` : 'Unlimited attempts'}\r\n                </div>\r\n            </div>\r\n            {quiz.has_passed && quiz.best_attempt && (\r\n                <div>\r\n                    You have already passed this quiz with {quiz.best_attempt.percentage}%\r\n                </div>\r\n            )}\r\n            <button \r\n                onClick={handleStart}\r\n                disabled={!quiz.can_attempt || isStarting}\r\n            >\r\n                {isStarting ? 'Starting...' : 'Start Quiz'}\r\n            </button>\r\n            <button onClick={onCancel}>Cancel</button>\r\n        </div>\r\n    );\r\n};\r\ndescribe('QuizTaker Component', () => {\r\n    const mockOnComplete = vi.fn();\r\n    const mockOnCancel = vi.fn();\r\n    const sampleQuiz = {\r\n        id: 1,\r\n        title: 'Sample Quiz',\r\n        description: 'A comprehensive test quiz',\r\n        passing_score: 80,\r\n        time_limit_minutes: 30,\r\n        max_attempts: 3,\r\n        show_correct_answers: true,\r\n        question_count: 3,\r\n        can_attempt: true,\r\n        has_passed: false,\r\n        best_attempt: null,\r\n        questions: [\r\n            {\r\n                id: 1,\r\n                type: 'multiple_choice',\r\n                type_label: 'Multiple Choice',\r\n                question: 'What is 2+2?',\r\n                explanation: 'Basic arithmetic',\r\n                points: 10,\r\n                options: [\r\n                    { id: 1, option_text: '3', is_correct: false },\r\n                    { id: 2, option_text: '4', is_correct: true },\r\n                    { id: 3, option_text: '5', is_correct: false },\r\n                ],\r\n            },\r\n            {\r\n                id: 2,\r\n                type: 'true_false',\r\n                type_label: 'True/False',\r\n                question: 'The sky is blue',\r\n                explanation: 'This is generally true',\r\n                points: 10,\r\n                options: [\r\n                    { id: 4, option_text: 'True', is_correct: true },\r\n                    { id: 5, option_text: 'False', is_correct: false },\r\n                ],\r\n            },\r\n            {\r\n                id: 3,\r\n                type: 'short_answer',\r\n                type_label: 'Short Answer',\r\n                question: 'What is the capital of France?',\r\n                explanation: 'The answer is Paris',\r\n                points: 10,\r\n                options: [],\r\n            },\r\n        ],\r\n    };\r\n    const defaultProps = {\r\n        quiz: sampleQuiz,\r\n        onComplete: mockOnComplete,\r\n        onCancel: mockOnCancel,\r\n    };\r\n    beforeEach(() => {\r\n        vi.clearAllMocks();\r\n        vi.clearAllTimers();\r\n        vi.useFakeTimers();\r\n    });\r\n    afterEach(() => {\r\n        vi.clearAllTimers();\r\n        vi.useRealTimers();\r\n    });\r\n    describe('Start Screen', () => {\r\n        it('displays quiz information on start screen', () => {\r\n            render(<QuizTaker {...defaultProps} />);\r\n            expect(screen.getByText('Sample Quiz')).toBeInTheDocument();\r\n            expect(screen.getByText('A comprehensive test quiz')).toBeInTheDocument();\r\n            expect(screen.getByText(/3 questions/i)).toBeInTheDocument();\r\n            expect(screen.getByText(/80% to pass/i)).toBeInTheDocument();\r\n            expect(screen.getByText(/30 minutes/i)).toBeInTheDocument();\r\n            expect(screen.getByText(/3 attempts allowed/i)).toBeInTheDocument();\r\n        });\r\n        it('shows unlimited attempts when max_attempts is null', () => {\r\n            const quizWithUnlimitedAttempts = {\r\n                ...sampleQuiz,\r\n                max_attempts: null,\r\n            };\r\n            render(<QuizTaker {...defaultProps} quiz={quizWithUnlimitedAttempts} />);\r\n            expect(screen.getByText(/unlimited attempts/i)).toBeInTheDocument();\r\n        });\r\n        it('shows no time limit when time_limit_minutes is null', () => {\r\n            const quizWithNoTimeLimit = {\r\n                ...sampleQuiz,\r\n                time_limit_minutes: null,\r\n            };\r\n            render(<QuizTaker {...defaultProps} quiz={quizWithNoTimeLimit} />);\r\n            expect(screen.getByText(/no time limit/i)).toBeInTheDocument();\r\n        });\r\n        it('shows passed alert when user has already passed', () => {\r\n            const 